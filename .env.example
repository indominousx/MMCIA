# --- PackRight Environment Configuration ---

# 1. Email Alert Settings (SMTP)
EMAIL_FROM=your-email@gmail.com
EMAIL_APP_PASSWORD=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# 2. Alert Recipients (Comma separated)
ALERT_RECIPIENTS=management@example.com
PRODUCTION_ALERT_RECIPIENTS=production@example.com
FINANCE_ALERT_RECIPIENTS=finance@example.com
PROCUREMENT_ALERT_RECIPIENTS=procurement@example.com
DAILY_REPORT_RECIPIENTS=ceo@example.com

# 3. Directory Settings
INPUT_DIR=data
OUTPUT_DIR=outputs
MODEL_DIR=models

# 4. SSL Settings (Optional - required for HTTPS on custom domains)
# Place your cert files in the project root and provide relative paths
SSL_CERT_PATH=
SSL_KEY_PATH=
