# Email alert settings
EMAIL_FROM=your-email@gmail.com
EMAIL_APP_PASSWORD=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Global recipients (comma separated)
ALERT_RECIPIENTS=recipient1@gmail.com,recipient2@gmail.com

# Role-specific recipients (comma separated, overrides global if set)
PRODUCTION_ALERT_RECIPIENTS=production-team@gmail.com
FINANCE_ALERT_RECIPIENTS=finance-team@gmail.com
PROCUREMENT_ALERT_RECIPIENTS=procurement-team@gmail.com

# Daily report recipients
DAILY_REPORT_RECIPIENTS=management@gmail.com

# Data directory settings
INPUT_DIR=data
OUTPUT_DIR=outputs
